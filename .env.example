# PostgreSQL (Docker)
POSTGRES_DB=lencondb
POSTGRES_USER=lencondb
POSTGRES_PASSWORD=changeme_secure_password
POSTGRES_PORT=5433

# Database connection (for backend/Prisma)
DATABASE_URL=postgresql://lencondb:changeme_secure_password@localhost:5433/lencondb

# JWT
JWT_ACCESS_SECRET=your_access_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_here

# Server
PORT=3000
NODE_ENV=development

# Encryption (for SMTP password storage)
ENCRYPTION_MASTER_KEY=your_32_char_encryption_key_here

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# SMTP (optional)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=user@example.com
# SMTP_PASS=password
