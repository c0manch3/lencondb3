# Production secrets — store in GitHub Secrets
# These are written to .env on the server during deployment

# PostgreSQL password (generate: openssl rand -base64 24)
POSTGRES_PASSWORD=

# JWT signing secrets (generate: openssl rand -base64 32)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# Encryption key for SMTP passwords (exactly 32 chars, generate: openssl rand -hex 16)
ENCRYPTION_MASTER_KEY=
